# Copy to .env and fill in real values: `cp .env.example .env`
# .env is gitignored — never commit real secrets. Every value the app reads is
# listed here; there are no hardcoded defaults in code.

# --- Database ---------------------------------------------------------------
# Async SQLAlchemy URL (note the +asyncpg driver). Matches docker-compose's db.
DATABASE_URL=postgresql+asyncpg://hodlin:hodlin@localhost:5432/hodlin

# --- Finnhub (news) — https://finnhub.io -----------------------------------
FINNHUB_API_KEY=your-finnhub-key
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_RATE_PER_MIN=60

# --- Massive (price bars) — https://massive.dev ----------------------------
MASSIVE_API_KEY=your-massive-key
MASSIVE_BASE_URL=https://api.massive.dev/v1
MASSIVE_RATE_PER_MIN=5
