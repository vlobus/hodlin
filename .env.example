# Copy to .env and fill in real values: `cp .env.example .env`
# .env is gitignored — never commit real secrets. Every value the app reads is
# listed here; there are no hardcoded defaults in code.

# --- Database ---------------------------------------------------------------
# Async SQLAlchemy URL (note the +asyncpg driver). Matches docker-compose's db.
DATABASE_URL=postgresql+asyncpg://hodlin:hodlin@localhost:5432/hodlin

# --- Finnhub (news) — https://finnhub.io -----------------------------------
FINNHUB_API_KEY=your-finnhub-key
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_RATE_PER_MIN=60

# --- Massive (price bars) — https://massive.dev ----------------------------
MASSIVE_API_KEY=your-massive-key
MASSIVE_BASE_URL=https://api.massive.dev/v1
MASSIVE_RATE_PER_MIN=5

# --- Anthropic (anomaly explanations) — https://console.anthropic.com ------
ANTHROPIC_API_KEY=your-anthropic-key
# One short call per anomaly; the cheap/fast tier is plenty.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Telegram (delivery) — token from @BotFather ----------------------------
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BASE_URL=https://api.telegram.org
# Your numeric user id (message @userinfobot to find it). This single id is
# both the alert destination and the allowlist — everyone else is ignored.
TELEGRAM_CHAT_ID=123456789
TELEGRAM_RATE_PER_MIN=30

# --- Runtime toggles (T10) — non-secret; safe defaults if omitted -----------
# Bind address/port. docker-compose sets HOST=0.0.0.0; local runs default to
# loopback. DEMO_MODE=true uses the committed seed bars + skips live news, so
# the Finnhub/Massive keys above go unused (but must still be present).
HOST=127.0.0.1
PORT=8000
DEMO_MODE=false
